{
    "openapi": "3.0.0",
    "info": {
        "title": "HealthAI Coach API",
        "description": "Documentation de l'API HealthAI Coach, gérée avec Lomkit REST API.",
        "version": "1.0.0"
    },
    "servers": [
        {
            "url": "http://localhost:80/api",
            "description": "Serveur de développement local"
        }
    ],
    "paths": {
        "/login": {
            "post": {
                "tags": [
                    "Auth"
                ],
                "summary": "Se connecter et récupérer un token Sanctum",
                "operationId": "f72526a176d358410e0862d5c20c6641",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "email",
                                    "password"
                                ],
                                "properties": {
                                    "email": {
                                        "type": "string",
                                        "format": "email",
                                        "example": "john@example.com"
                                    },
                                    "password": {
                                        "type": "string",
                                        "format": "password",
                                        "example": "password123"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Authentification réussie, token retourné"
                    },
                    "401": {
                        "description": "Identifiants invalides"
                    }
                }
            }
        },
        "/logout": {
            "post": {
                "tags": [
                    "Auth"
                ],
                "summary": "Se déconnecter (Révocation du token actuel)",
                "operationId": "3599bb21fa2c90996e7f13e2dfbbaabf",
                "responses": {
                    "200": {
                        "description": "Déconnexion réussie"
                    },
                    "401": {
                        "description": "Non authentifié"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            }
        },
        "/register": {
            "post": {
                "tags": [
                    "Register"
                ],
                "summary": "Créer un nouveau compte utilisateur avec profil de santé",
                "operationId": "68dd04b00240636c7fc26e9c49ca8cd1",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "email",
                                    "password",
                                    "password_confirmation",
                                    "age",
                                    "gender",
                                    "weight",
                                    "height",
                                    "body_fat_pct",
                                    "disease_type",
                                    "severity",
                                    "physical_activity_level",
                                    "daily_caloric_intake",
                                    "goal"
                                ],
                                "properties": {
                                    "email": {
                                        "type": "string",
                                        "format": "email",
                                        "example": "john.doe@example.com"
                                    },
                                    "password": {
                                        "description": "Minimum 6 caractères",
                                        "type": "string",
                                        "format": "password",
                                        "example": "password123"
                                    },
                                    "password_confirmation": {
                                        "type": "string",
                                        "format": "password",
                                        "example": "password123"
                                    },
                                    "age": {
                                        "description": "Entre 1 et 130",
                                        "type": "integer",
                                        "example": 35
                                    },
                                    "gender": {
                                        "type": "string",
                                        "enum": [
                                            "male",
                                            "female",
                                            "other"
                                        ],
                                        "example": "male"
                                    },
                                    "weight": {
                                        "description": "Poids en kg (entre 1 et 500)",
                                        "type": "number",
                                        "format": "float",
                                        "example": 75.5
                                    },
                                    "height": {
                                        "description": "Taille en cm (entre 1 et 300)",
                                        "type": "integer",
                                        "example": 180
                                    },
                                    "body_fat_pct": {
                                        "description": "Pourcentage de masse grasse (entre 1 et 100)",
                                        "type": "integer",
                                        "example": 18
                                    },
                                    "disease_type": {
                                        "type": "string",
                                        "example": "Diabète de type 2"
                                    },
                                    "severity": {
                                        "type": "string",
                                        "example": "Modérée"
                                    },
                                    "physical_activity_level": {
                                        "type": "string",
                                        "example": "Actif"
                                    },
                                    "daily_caloric_intake": {
                                        "description": "Apport calorique journalier ciblé",
                                        "type": "integer",
                                        "example": 2200
                                    },
                                    "goal": {
                                        "type": "string",
                                        "maxLength": 500,
                                        "example": "Perdre du poids tout en stabilisant la glycémie."
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Utilisateur créé avec succès"
                    },
                    "422": {
                        "description": "Erreur de validation (ex: email déjà pris, mot de passe trop court, etc.)"
                    }
                }
            }
        },
